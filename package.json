{
  "name": "envault",
  "displayName": "Envault",
  "description": "Gestión de perfiles .env por empresa/rama sin tocar el repositorio",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envault",
          "title": "Envault",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "envault": [
        {
          "id": "envaultTree",
          "name": "Perfiles",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "envault.addProfile",
        "title": "Nuevo Perfil",
        "icon": "$(add)"
      },
      {
        "command": "envault.editProfile",
        "title": "Editar Perfil",
        "icon": "$(edit)"
      },
      {
        "command": "envault.deleteProfile",
        "title": "Eliminar Perfil",
        "icon": "$(trash)"
      },
      {
        "command": "envault.applyProfile",
        "title": "Aplicar Perfil",
        "icon": "$(check)"
      },
      {
        "command": "envault.viewProfileReadOnly",
        "title": "Ver Perfil (Solo lectura)",
        "icon": "$(file-text)"
      },
      {
        "command": "envault.importFromEnv",
        "title": "Importar .env actual",
        "icon": "$(file-add)"
      },
      {
        "command": "envault.showExpandedWorkspaces",
        "title": "Cambiar a vista ampliada",
        "icon": "$(eye)"
      },
      {
        "command": "envault.showFocusedWorkspace",
        "title": "Cambiar a vista enfocada",
        "icon": "$(eye-closed)"
      },
      {
        "command": "envault.toggleOtherWorkspaces",
        "title": "Alternar vista de workspaces",
        "icon": "$(eye)"
      },
      {
        "command": "envault.refresh",
        "title": "Refrescar",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "envault.addProfile",
          "when": "view == envaultTree",
          "group": "navigation"
        },
        {
          "command": "envault.showExpandedWorkspaces",
          "when": "view == envaultTree && !envault.showOtherWorkspaces",
          "group": "navigation"
        },
        {
          "command": "envault.showFocusedWorkspace",
          "when": "view == envaultTree && envault.showOtherWorkspaces",
          "group": "navigation"
        },
        {
          "command": "envault.refresh",
          "when": "view == envaultTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "envault.applyProfile",
          "when": "viewItem == profileCurrent",
          "group": "inline@1"
        },
        {
          "command": "envault.viewProfileReadOnly",
          "when": "viewItem == profileExternal",
          "group": "inline@1"
        },
        {
          "command": "envault.editProfile",
          "when": "viewItem == profileCurrent",
          "group": "inline@2"
        },
        {
          "command": "envault.deleteProfile",
          "when": "viewItem == profileCurrent",
          "group": "inline@3"
        },
        {
          "command": "envault.importFromEnv",
          "when": "viewItem == workspace",
          "group": "context"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}